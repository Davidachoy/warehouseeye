# AMD vLLM endpoint base URL (OpenAI-compatible).
# Use the server base URL (without /v1) so backend health check can call `${AMD_URL}/health`.
AMD_URL=http://<INSTANCE_IP>:8000

# Model selection
# - Set AMD_PROFILE=dev to use AMD_MODEL_DEV
# - Set AMD_PROFILE=prod to use AMD_MODEL_PROD
# - AMD_MODEL (if set) overrides both
AMD_PROFILE=dev
AMD_MODEL_DEV=Qwen/Qwen3-VL-8B-Instruct
AMD_MODEL_PROD=Qwen/Qwen3-VL-32B-Instruct
# AMD_MODEL=Qwen/Qwen3-VL-8B-Instruct

# Optional auth (only if your vLLM server requires it)
# AMD_API_KEY=

# Runtime tuning
AMD_CONCURRENCY=8
AMD_TIMEOUT_SEC=45
AMD_MAX_TOKENS=300
# VLM quality gate in VisionAnalyzer (skip VLM call below these bbox dimensions)
WAREHOUSEEYE_VLM_MIN_WIDTH=30
WAREHOUSEEYE_VLM_MIN_HEIGHT=60

# Prompt files (optional overrides)
ACTIVITY_PROMPT_PATH=prompts/activity_extraction.txt
ACTIVITY_PROMPT_STRICT_PATH=prompts/activity_extraction_strict.txt
